# ─────────────────────────────────────────────────────────────────────────────
# The Social Seen — environment variables
#
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# From https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Sentry ──────────────────────────────────────────────────────────────────
# Create project at https://sentry.io → Settings → Projects → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@xxx.ingest.sentry.io/xxxxxxx

# Build-time only — used to upload source maps.
# Create at https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:read, project:write, org:read
SENTRY_AUTH_TOKEN=sntryu_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── PostHog ─────────────────────────────────────────────────────────────────
# From https://posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx

# Either https://eu.i.posthog.com or https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ─── Supabase CLI ────────────────────────────────────────────────────────────
# Personal access token for running `supabase` CLI commands (migrations, etc).
# Only used locally; not read by the app at runtime.
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend ──────────────────────────────────────────────────────────────────
# Transactional email — sends welcome, booking confirmations, OTP, reminders.
# Get from https://resend.com → API Keys → Create API Key (sending access).
# Until your custom domain is verified, mails send FROM `onboarding@resend.dev`.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe (P2-7) ───────────────────────────────────────────────────────────
# Stripe Checkout integration for paid event bookings. Test mode until
# go-live. Get from https://dashboard.stripe.com/test/apikeys.
#
# Publishable key — safe to expose to the browser. Used by @stripe/stripe-js
# to load Stripe.js for the Checkout redirect.
# (Short placeholder "..." — GitHub's secret scanner flags longer fake
#  pk_test_/sk_test_/whsec_ strings as real keys.)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key — server-side only. Never import in files without 'use server'
# or in src/app/api/ routes. Restricted key preferred (with Checkout
# Sessions: Write, PaymentIntents: Read, Refunds: Write, Customers: Write).
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — generated AFTER you deploy the webhook endpoint.
# In dev: `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# prints a whsec_... that matches your local run.
# In prod: https://dashboard.stripe.com/test/webhooks → endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare Turnstile (Phase 2.5 Batch 1) ────────────────────────────────
# Protects /contact and /collaborate forms from automated abuse. Free tier,
# unlimited. Sign up at https://dash.cloudflare.com → Turnstile → Add site.
#
# Site key — safe to expose to the browser; loaded by the Turnstile widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# Secret key — server-side only. Used by src/lib/turnstile/verify.ts to
# verify tokens with Cloudflare's siteverify endpoint. If unset, the
# verifier fails open (useful for early-stage preview deploys; a warning
# is logged in production).
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ─── Twilio SMS (Phase 2.5 Batch 5) ──────────────────────────────────────────
# Transactional SMS for venue reveals + day-of event reminders. Alphanumeric
# sender — no number purchase needed, but outbound-only (no STOP-via-SMS).
# Opt-out is honoured via profiles.sms_consent + the /profile preferences UI.
#
# Account SID — starts with "AC..." (from https://console.twilio.com).
TWILIO_ACCOUNT_SID=AC...

# Auth token — 32 hex chars. Rotates independently from the SID.
TWILIO_AUTH_TOKEN=...

# Alphanumeric sender (max 11 chars, no special chars beyond space), or a
# full E.164 number (+44...) once a UK long code is purchased.
TWILIO_SENDER_ID=SocialSeen

# Optional: when set, every SMS is redirected to this number instead of
# the real recipient (body is prefixed with the intended recipient).
# Mirrors SANDBOX_FALLBACK_RECIPIENT for email. Auto-ignored in production.
SMS_SANDBOX_FALLBACK_RECIPIENT=+44...
